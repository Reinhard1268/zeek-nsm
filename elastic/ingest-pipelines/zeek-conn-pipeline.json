{
  "_meta": {
    "file": "zeek-conn-pipeline.json",
    "location": "05-zeek-nsm/elastic/ingest-pipelines/zeek-conn-pipeline.json",
    "description": "Zeek conn.log ingest pipeline for Elasticsearch 8.x"
  },
  "description": "Zeek conn.log ingest pipeline — maps fields to ECS",
  "processors": [
    { "set": { "field": "event.dataset", "value": "zeek.conn" } },
    { "set": { "field": "event.module",  "value": "zeek" } },
    {
      "date": {
        "field": "ts",
        "formats": ["UNIX"],
        "target_field": "@timestamp",
        "ignore_failure": false
      }
    },
    { "rename": { "field": "id.orig_h",    "target_field": "source.ip",            "ignore_missing": true } },
    { "rename": { "field": "id.orig_p",    "target_field": "source.port",          "ignore_missing": true } },
    { "rename": { "field": "id.resp_h",    "target_field": "destination.ip",       "ignore_missing": true } },
    { "rename": { "field": "id.resp_p",    "target_field": "destination.port",     "ignore_missing": true } },
    { "rename": { "field": "proto",        "target_field": "network.transport",    "ignore_missing": true } },
    { "rename": { "field": "service",      "target_field": "network.protocol",     "ignore_missing": true } },
    { "rename": { "field": "duration",     "target_field": "event.duration",       "ignore_missing": true } },
    { "rename": { "field": "orig_bytes",   "target_field": "source.bytes",         "ignore_missing": true } },
    { "rename": { "field": "resp_bytes",   "target_field": "destination.bytes",    "ignore_missing": true } },
    { "rename": { "field": "orig_pkts",    "target_field": "source.packets",       "ignore_missing": true } },
    { "rename": { "field": "resp_pkts",    "target_field": "destination.packets",  "ignore_missing": true } },
    { "rename": { "field": "conn_state",   "target_field": "zeek.conn.state",      "ignore_missing": true } },
    { "rename": { "field": "history",      "target_field": "zeek.conn.history",    "ignore_missing": true } },
    { "rename": { "field": "missed_bytes", "target_field": "zeek.conn.missed_bytes","ignore_missing": true } },
    { "rename": { "field": "local_orig",   "target_field": "zeek.conn.local_orig", "ignore_missing": true } },
    { "rename": { "field": "local_resp",   "target_field": "zeek.conn.local_resp", "ignore_missing": true } },
    {
      "script": {
        "lang": "painless",
        "description": "Calculate total network bytes",
        "source": "if (ctx.source?.bytes != null && ctx.destination?.bytes != null) { ctx.network = ctx.network ?: [:]; ctx.network.bytes = ctx.source.bytes + ctx.destination.bytes; }"
      }
    },
    { "geoip": { "field": "destination.ip", "target_field": "destination.geo", "ignore_missing": true, "ignore_failure": true } },
    { "geoip": { "field": "source.ip",      "target_field": "source.geo",      "ignore_missing": true, "ignore_failure": true } },
    { "set": { "field": "event.kind",     "value": "event" } },
    { "set": { "field": "event.category", "value": ["network"] } },
    { "set": { "field": "event.type",     "value": ["connection", "info"] } },
    { "remove": { "field": ["ts", "uid", "_write_ts"], "ignore_missing": true } }
  ],
  "on_failure": [
    { "set": { "field": "error.message",  "value": "{{ _ingest.on_failure_message }}" } },
    { "set": { "field": "event.dataset",  "value": "zeek.conn" } }
  ]
}
