{
  "_meta": {
    "file": "zeek-http-pipeline.json",
    "location": "05-zeek-nsm/elastic/ingest-pipelines/zeek-http-pipeline.json",
    "description": "Zeek http.log ingest pipeline for Elasticsearch 8.x"
  },
  "description": "Zeek http.log ingest pipeline — maps fields to ECS",
  "processors": [
    { "set": { "field": "event.dataset", "value": "zeek.http" } },
    { "set": { "field": "event.module",  "value": "zeek" } },
    {
      "date": {
        "field": "ts",
        "formats": ["UNIX"],
        "target_field": "@timestamp",
        "ignore_failure": false
      }
    },
    { "rename": { "field": "id.orig_h",         "target_field": "source.ip",                   "ignore_missing": true } },
    { "rename": { "field": "id.orig_p",         "target_field": "source.port",                 "ignore_missing": true } },
    { "rename": { "field": "id.resp_h",         "target_field": "destination.ip",              "ignore_missing": true } },
    { "rename": { "field": "id.resp_p",         "target_field": "destination.port",            "ignore_missing": true } },
    { "rename": { "field": "method",            "target_field": "http.request.method",         "ignore_missing": true } },
    { "rename": { "field": "host",              "target_field": "url.domain",                  "ignore_missing": true } },
    { "rename": { "field": "uri",               "target_field": "url.path",                    "ignore_missing": true } },
    { "rename": { "field": "referrer",          "target_field": "http.request.referrer",       "ignore_missing": true } },
    { "rename": { "field": "user_agent",        "target_field": "user_agent.original",         "ignore_missing": true } },
    { "rename": { "field": "status_code",       "target_field": "http.response.status_code",   "ignore_missing": true } },
    { "rename": { "field": "request_body_len",  "target_field": "http.request.body.bytes",     "ignore_missing": true } },
    { "rename": { "field": "response_body_len", "target_field": "http.response.body.bytes",    "ignore_missing": true } },
    { "rename": { "field": "resp_mime_types",   "target_field": "zeek.http.resp_mime_types",   "ignore_missing": true } },
    { "rename": { "field": "tags",              "target_field": "zeek.http.tags",              "ignore_missing": true } },
    { "rename": { "field": "username",          "target_field": "user.name",                   "ignore_missing": true } },
    { "rename": { "field": "proxied",           "target_field": "zeek.http.proxied",           "ignore_missing": true } },
    {
      "user_agent": {
        "field": "user_agent.original",
        "target_field": "user_agent",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "uri_parts": {
        "field": "url.path",
        "target_field": "url",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "script": {
        "lang": "painless",
        "description": "Build full URL",
        "source": "if (ctx.url?.domain != null && ctx.url?.path != null) { ctx.url.full = 'http://' + ctx.url.domain + ctx.url.path; }"
      }
    },
    { "geoip": { "field": "destination.ip", "target_field": "destination.geo", "ignore_missing": true, "ignore_failure": true } },
    { "geoip": { "field": "source.ip",      "target_field": "source.geo",      "ignore_missing": true, "ignore_failure": true } },
    { "set": { "field": "event.kind",     "value": "event" } },
    { "set": { "field": "event.category", "value": ["network", "web"] } },
    { "set": { "field": "event.type",     "value": ["access"] } },
    {
      "set": {
        "field": "event.outcome",
        "value": "success",
        "if": "ctx.http?.response?.status_code != null && ctx.http.response.status_code < 400"
      }
    },
    {
      "set": {
        "field": "event.outcome",
        "value": "failure",
        "if": "ctx.http?.response?.status_code != null && ctx.http.response.status_code >= 400"
      }
    },
    { "remove": { "field": ["ts", "uid", "_write_ts", "trans_depth", "version"], "ignore_missing": true } }
  ],
  "on_failure": [
    { "set": { "field": "error.message", "value": "{{ _ingest.on_failure_message }}" } },
    { "set": { "field": "event.dataset", "value": "zeek.http" } }
  ]
}
